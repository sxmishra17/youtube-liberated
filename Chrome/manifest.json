{
  "manifest_version": 3,
  "name": "YouTube Liberated",
  "version": "1.1.0",
  "description": "Lightweight extension to block ads, Shorts, Community Posts, and play audio in the background on YouTube.",

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "*://*.youtube.com/*"
  ],

  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "YouTube Liberated",
    "default_popup": "popup/popup.html"
  },

  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "css": ["content/content.css"],
      "js": ["content/content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
